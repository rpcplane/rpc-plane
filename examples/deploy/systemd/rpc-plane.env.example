# EnvironmentFile for the rpc-plane systemd unit.
# Install to /etc/rpc-plane/rpc-plane.env with mode 0640, owned by rpc-plane.
# The ${VAR} refs in rpc-plane.toml expand to these at startup.
HELIUS_API_KEY=
QUICKNODE_API_KEY=
TRITON_API_KEY=

# Optional: log level (error|warn|info|debug|trace)
# RUST_LOG=info
